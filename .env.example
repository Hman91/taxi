# Copy to ".env" in the repo root **or** inside `backend/` (not committed).
# `backend/config.py` loads both: `taxi/.env` first, then `backend/.env` for missing vars.

# Database (PostgreSQL). Neon https://neon.tech is PostgreSQL-only — paste their URL as-is:
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require
# (backend normalizes postgres:// → postgresql+psycopg2 for SQLAlchemy + Alembic.)
# Local default if unset:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/taxi

# --- Chat translation (see README) ---
# Default when unset: google (translates for the receiver's preferred_language).
# Production (Render) often uses "none" to avoid outbound Google calls; that disables translation.
# For local dev with translation, omit this line or set:
# TRANSLATION_PROVIDER=google
# To match production (no API translation):
# TRANSLATION_PROVIDER=none

# TRANSLATION_TIMEOUT_SECONDS=5

# --- Password reset (passenger/driver app signup reset flow) ---
# Production: PASSWORD_RESET_DEV_MODE=0.
# When "1", no mail is sent; code is logged on the server only (email_sent:false in API).
#
# Render Free: outbound SMTP ports 25/465/587 are blocked — use Resend over HTTPS instead of Gmail SMTP:
#   RESEND_API_KEY=re_xxxxx           # https://resend.com/api-keys
#   RESEND_FROM_EMAIL=noreply@your-domain   # Must be verified in Resend (testing: onboarding@resend.dev )
# Fallback after Resend fails (e.g. local dev): SMTP_* below.
#
# SMTP_USE_TLS=1 with port 587 (STARTTLS) is the default Gmail setup.
# If your host blocks port 587, try implicit SSL instead:
#   SMTP_SSL=1
#   SMTP_PORT=465
#   SMTP_HOST=smtp.gmail.com
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_TLS=1
# SMTP_SSL=0
# SMTP_USERNAME=you@gmail.com
# SMTP_PASSWORD=app_password_no_spaces_ok
# SMTP_FROM_EMAIL=you@gmail.com
# SMTP_TIMEOUT_SECONDS=25

# PASSWORD_RESET_DEV_MODE=0
#
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=

# --- Flight arrivals (Owner / Operator / Driver "Today's arrivals") ---
# Without AIRLABS_API_KEY the API serves a tiny built-in sample list only.
# Get a key from https://airlabs.co and set in `taxi/.env` or `backend/.env`:
# AIRLABS_API_KEY=your_key_here