# Copy to .env and fill in (never commit .env).
# On Render, set the same keys in Environment.

# Supabase → Database → Connect → Session pooler → URI
# postgresql://postgres.xxxx:[YOUR-PASSWORD]@...pooler...:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/taxi

# Either name works in backend/config.py (Flask-JWT and sessions)
SECRET_KEY=0c0f3c01ab91f9df1c2df5a8e29818b3b08bd89a734f5dd4fcc38969c066bbc9
# FLASK_SECRET_KEY=optional-if-SECRET_KEY-is-set

# Optional: Google OAuth (must match Flutter)
# GOOGLE_OAUTH_CLIENT_ID=
