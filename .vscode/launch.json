{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "taxi_pro (Chrome + API to host)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/flutter/taxi_pro",
      "program": "lib/main.dart",
      "deviceId": "chrome",
      "toolArgs": [
        "--dart-define=API_BASE_URL=http://127.0.0.1:5000"
      ]
    },
    {
      "name": "taxi_pro (device — default API per platform)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/flutter/taxi_pro",
      "program": "lib/main.dart"
    }
  ]
}
